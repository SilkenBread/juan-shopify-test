        "product_detail_wBF8HP": {
          "type": "product_detail",
          "settings": {
            "title": "Details",
            "content": "<p>The Emerald Cut Solitaire in 18k yellow gold with a lab grown emerald diamond.<br/>This design reflects the enduring simplicity of a classic solitaire engagement ring. Crafted to sit balanced on the finger and pair seamlessly with a wedding band, the elevated four-prong basket allows light to enter from all angles, enhancing the diamond’s depth and clarity.</p><p><strong>SKU:</strong> LGD233112<br/><strong>Center Stone:</strong> Emerald Cut<br/><strong>Setting: </strong>Four Prong Solitaire<br/><strong>Band Width: </strong>Approx. 1.8–2.0mm<br/><strong>Metal: </strong>18k Yellow Gold<br/><strong>Profile:</strong> Elevated basket for flush band pairing<br/><strong>Designed by: </strong>Robert Palma</p><h5>Lab Grown Diamond</h5><p><strong>Origin: </strong>Lab grown using advanced zero-emission technology.<br/><strong>Certification: </strong>Independently graded and certified</p>"
          }
        },
