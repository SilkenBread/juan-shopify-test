{%- liquid
  assign selected_variant = product.selected_or_first_available_variant
  assign card_image = selected_variant.featured_image | default: product.featured_image
  assign card_image_id = 'card-img-' | append: section.id | append: '-' | append: product.id

  assign metal_option = blank
  assign selected_variant_metal = ''
  for option in product.options_with_values
    assign option_name_downcase = option.name | downcase
    if option_name_downcase == 'metal'
      assign metal_option = option
      break
    endif
  endfor

  if metal_option != blank
    case metal_option.position
      when 1
        assign selected_variant_metal = selected_variant.option1
      when 2
        assign selected_variant_metal = selected_variant.option2
      when 3
        assign selected_variant_metal = selected_variant.option3
    endcase
  endif
-%}

<div class="product-card">
  <a href="{{ product.url }}" class="product-card__image-link" aria-label="{{ product.title | escape }}">
    {%- if card_image != blank -%}
      <img
        src="{{ card_image | image_url: width: 640 }}"
        alt="{{ card_image.alt | default: product.title | escape }}"
        id="{{ card_image_id }}"
        class="product-card__image"
        width="320"
        height="320"
        loading="lazy"
      >
    {%- endif -%}
  </a>

  <div class="product-card__info">
    <div class="product-card__text">
      <h3 class="product-card__title">
        <a href="{{ product.url }}">{{ product.title }}</a>
      </h3>
      <p class="product-card__price">{{ product.price | money }}</p>
    </div>

    {%- if metal_option != blank and section.blocks.size > 0 -%}
      <div class="product-card__swatches">
        {%- liquid
          assign has_active_swatch = false
        -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'metal_option' and block.settings.metal_value != blank -%}
          {%- liquid
            assign value = block.settings.metal_value
            assign swatch_image = blank
            if block.settings.image != blank
              assign swatch_image = block.settings.image
            endif

            assign variant_for_metal = blank
            for variant in product.variants
              assign variant_metal_value = ''
              case metal_option.position
                when 1
                  assign variant_metal_value = variant.option1
                when 2
                  assign variant_metal_value = variant.option2
                when 3
                  assign variant_metal_value = variant.option3
              endcase

              if variant_metal_value == value
                assign variant_for_metal = variant
                break
              endif
            endfor

            assign swatch_image_url = ''
            if swatch_image != blank
              assign swatch_image_url = swatch_image | image_url: width: 120
            elsif variant_for_metal != blank and variant_for_metal.featured_image != blank
              assign swatch_image_url = variant_for_metal.featured_image | image_url: width: 640
            endif

            assign is_active = false
          -%}

          {%- if variant_for_metal != blank -%}
            {%- liquid
              if selected_variant_metal != '' and value == selected_variant_metal
                assign is_active = true
                assign has_active_swatch = true
              elsif has_active_swatch == false
                assign is_active = true
                assign has_active_swatch = true
              endif
            -%}
            <button
              type="button"
              class="product-card__swatch{% if is_active %} product-card__swatch--active{% endif %} swatch--{{ value | handleize }}"
              aria-label="Select {{ value }}"
              title="{{ value }}"
              data-target-img="{{ card_image_id }}"
              data-image-url="{{ swatch_image_url }}"
              data-metal-value="{{ value }}"
              data-variant-id="{{ variant_for_metal.id }}"
            >
              {%- if swatch_image_url != blank -%}
                <img
                  src="{{ swatch_image_url }}"
                  alt="{{ value | escape }}"
                  class="product-card__swatch-image"
                  width="30"
                  height="30"
                  loading="lazy"
                >
              {%- else -%}
                <span class="product-card__swatch-fallback">{{ value | slice: 0, 2 | upcase }}</span>
              {%- endif -%}
            </button>
          {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>
