{%- liquid
  assign selected_variant = product.selected_or_first_available_variant
  assign card_image = selected_variant.featured_image | default: product.featured_image
-%}

<div class="matching-card">
  <a href="{{ product.url }}" class="matching-card__image-link" aria-label="{{ product.title | escape }}">
    {%- if card_image != blank -%}
      <img
        src="{{ card_image | image_url: width: 640 }}"
        alt="{{ card_image.alt | default: product.title | escape }}"
        class="matching-card__image"
        width="320"
        height="320"
        loading="lazy"
      >
    {%- endif -%}
  </a>

  <div class="matching-card__info">
    <h3 class="matching-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <p class="matching-card__price">{{ product.price | money }}</p>
  </div>
</div>
