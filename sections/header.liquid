<header class="site-header full-width">
  <!-- Hamburger menu mobile -->
  <button class="site-header__hamburger" aria-label="Menu" aria-expanded="false" aria-controls="site-header-nav">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <line x1="1" y1="5" x2="19" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="1" y1="10" x2="19" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="1" y1="15" x2="19" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- Logo -->
  <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }} - Home">
    <img
      src="{{ 'logo.svg' | asset_url }}"
      alt="{{ shop.name }}"
      width="349"
      height="66"
      loading="eager"
    >
  </a>

  <!-- Navigation (hidden on mobile) -->
  <nav class="site-header__nav" id="site-header-nav" aria-label="Primary navigation">
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}" class="site-header__link">{{ link.title }}</a>
    {% endfor %}
  </nav>

  <!-- User action icons -->
  <div class="site-header__icons">
    <a href="/search" class="site-header__icon site-header__icon--desktop-only" aria-label="Search">
      {{ 'icon-search.svg' | inline_asset_content }}
    </a>
    <a href="/collections" class="site-header__icon site-header__icon--desktop-only" aria-label="Favorites">
      {{ 'icon-favorites.svg' | inline_asset_content }}
    </a>
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}" class="site-header__icon site-header__icon--desktop-only site-header__icon--account">
        <span slot="signed-out-avatar" aria-hidden="true">
          {{ 'icon-account-2.svg' | inline_asset_content }}
        </span>
      </shopify-account>
    {% else %}
      <a href="{{ routes.account_login_url }}" class="site-header__icon site-header__icon--desktop-only site-header__icon--account" aria-label="Account">
        {{ 'icon-account-2.svg' | inline_asset_content }}
      </a>
    {% endif %}
    <a href="{{ routes.cart_url }}" class="site-header__icon" aria-label="Cart">
      {% if cart.item_count > 0 %}
        <sup class="site-header__cart-count">{{ cart.item_count }}</sup>
      {% endif %}
      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

<script>
  document.querySelector('.site-header__hamburger')?.addEventListener('click', function () {
    const nav = document.getElementById('site-header-nav');
    const isOpen = nav.classList.toggle('site-header__nav--open');
    this.setAttribute('aria-expanded', isOpen);
  });
</script>

{% stylesheet %}
  /* ── Site Header ── */
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 30px 12px;
    position: relative;
    background-color: var(--color-background);
  }
  /* Hamburger */
  .site-header__hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--color-foreground);
  }
  /* Logo */
  .site-header__logo {
    display: flex;
    align-items: center;
    margin-right: 30px;
    flex-shrink: 1;
    min-width: 0;
  }
  .site-header__logo img {
    display: block;
    width: 349px;
    max-width: 100%;
    height: auto;
  }
  /* Navigation */
  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 12px 20px;
    flex: 1;
    flex-wrap: wrap;
    min-width: 0;
  }
  .site-header__link {
    font-family: var(--font-primary--family);
    font-weight: var(--font-primary--weight);
    font-size: 14px;
    line-height: 1.4;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
    white-space: nowrap;
  }
  .site-header__link:hover {
    text-decoration: underline;
  }
  /* Icons */
  .site-header__icons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
    margin-left: 30px;
  }
  .site-header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--color-foreground);
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .site-header__icon--account {
    margin-left: -8px;
  }
  .site-header__icon svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .site-header__cart-count {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
    font-size: 10px;
  }
  /* ── Mobile ── */
  @media (max-width: 767px) {
    .site-header {
      padding: 16px 10px;
    }
    .site-header__hamburger {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
    }
    .site-header__logo {
      flex: 1;
      justify-content: center;
      margin-right: 0;
    }
    .site-header__logo img {
      width: 180px;
    }
    .site-header__nav {
      display: flex;
      flex-direction: column;
      flex-wrap: nowrap;
      align-items: flex-start;
      justify-content: flex-start;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-background);
      padding: 0 10px;
      gap: 16px;
      z-index: 10;
      max-height: 0;
      transform: translateY(-8px);
      visibility: hidden;
      pointer-events: none;
      overflow: hidden;
      transition:
        max-height 0.36s cubic-bezier(0.22, 1, 0.36, 1),
        transform 0.36s cubic-bezier(0.22, 1, 0.36, 1),
        visibility 0s linear 0.36s,
        padding 0.36s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .site-header__nav--open {
      padding: 16px 10px;
      max-height: 320px;
      transform: translateY(0);
      visibility: visible;
      pointer-events: auto;
      transition:
        max-height 0.36s cubic-bezier(0.22, 1, 0.36, 1),
        transform 0.36s cubic-bezier(0.22, 1, 0.36, 1),
        visibility 0s linear 0s,
        padding 0.36s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .site-header__icon--desktop-only {
      display: none;
    }
    .site-header__icons {
      flex: 0 0 auto;
      margin-left: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
