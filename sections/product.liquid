<script>
  document.addEventListener('DOMContentLoaded', function () {
    /* ===================== Swiper (existing) ===================== */
    var mobileQuery = window.matchMedia('(max-width: 767px)');
    var mainSwiper = null;
    var thumbsSwiper = null;

    function initSwipers() {
      if (typeof Swiper === 'undefined') return;

      thumbsSwiper = new Swiper('.product-thumbs__swiper', {
        slidesPerView: 'auto',
        spaceBetween: 8,
        watchSlidesProgress: true,
      });

      mainSwiper = new Swiper('.product-gallery__swiper', {
        slidesPerView: 1,
        spaceBetween: 0,
        navigation: {
          nextEl: '.swiper-button-next',
          prevEl: '.swiper-button-prev',
        },
        thumbs: {
          swiper: thumbsSwiper,
        },
      });
    }

    function destroySwipers() {
      if (mainSwiper) {
        mainSwiper.destroy(true, true);
        mainSwiper = null;
      }
      if (thumbsSwiper) {
        thumbsSwiper.destroy(true, true);
        thumbsSwiper = null;
      }
    }

    function handleViewportChange(e) {
      if (e.matches) {
        initSwipers();
      } else {
        destroySwipers();
      }
    }

    mobileQuery.addEventListener('change', handleViewportChange);

    if (mobileQuery.matches) {
      initSwipers();
    }

    /* ===================== Variant Selection ===================== */
    var variantDataEl = document.querySelector('[data-product-variants]');
    if (!variantDataEl) return;
    var variants = JSON.parse(variantDataEl.textContent);

    var variantIdInput = document.querySelector('[data-variant-id]');
    var selectedMetalSpan = document.querySelector('[data-selected-metal]');
    var selectedRingSizeSpan = document.querySelector('[data-selected-ring-size]');
    var priceDisplay = document.querySelector('.product-info__price .product-info__price-value');
    var metalButtons = document.querySelectorAll('.metal-btn');
    var ringSizeSelect = document.querySelector('[data-ring-size-select]');
    var caratSlider = document.querySelector('[data-carat-slider]');
    var caratDisplay = document.querySelector('[data-carat-display]');
    var addToCartBtn = document.querySelector('.product-form__submit');

    var selectedMetal = selectedMetalSpan ? selectedMetalSpan.textContent.trim() : '';
    var selectedRingSize = ringSizeSelect ? ringSizeSelect.value : '';

    function findVariant(metal, ringSize) {
      for (var i = 0; i < variants.length; i++) {
        if (variants[i].option1 === metal && variants[i].option2 === ringSize) {
          return variants[i];
        }
      }
      return null;
    }

    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2) + ' USD';
    }

    function updateVariant() {
      var variant = findVariant(selectedMetal, selectedRingSize);
      if (variant) {
        variantIdInput.value = variant.id;

        if (priceDisplay) {
          priceDisplay.textContent = formatMoney(variant.price);
        }

        var url = new URL(window.location);
        url.searchParams.set('variant', variant.id);
        window.history.replaceState({}, '', url);

        if (addToCartBtn) {
          if (variant.available) {
            addToCartBtn.disabled = false;
            addToCartBtn.value = 'ADD TO BAG';
          } else {
            addToCartBtn.disabled = true;
            addToCartBtn.value = 'SOLD OUT';
          }
        }
      } else if (addToCartBtn) {
        addToCartBtn.disabled = true;
        addToCartBtn.value = 'UNAVAILABLE';
      }
    }

    metalButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        metalButtons.forEach(function (b) {
          b.classList.remove('metal-btn--active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('metal-btn--active');
        btn.setAttribute('aria-pressed', 'true');

        selectedMetal = btn.getAttribute('data-metal-value');
        if (selectedMetalSpan) selectedMetalSpan.textContent = selectedMetal;

        updateVariant();
      });
    });

    if (ringSizeSelect) {
      ringSizeSelect.addEventListener('change', function () {
        selectedRingSize = this.value;
        if (selectedRingSizeSpan) selectedRingSizeSpan.textContent = selectedRingSize;
        updateVariant();
      });
    }

    var caratTooltip = document.querySelector('[data-carat-tooltip]');

    function updateCaratSlider() {
      if (!caratSlider) return;
      var min = parseFloat(caratSlider.min);
      var max = parseFloat(caratSlider.max);
      var val = parseFloat(caratSlider.value);
      var ratio = (val - min) / (max - min);
      var progress = ratio * 100;
      var track = caratSlider.closest('.carat-range__track');
      if (track) {
        track.style.setProperty('--carat-progress', progress + '%');
        // Compensate for thumb width (22px) so tooltip aligns with thumb center
        var thumbHalf = 11;
        var trackWidth = caratSlider.offsetWidth;
        var thumbPos = thumbHalf + ratio * (trackWidth - 2 * thumbHalf);
        track.style.setProperty('--carat-tooltip-left', thumbPos + 'px');
      }
      if (caratDisplay) caratDisplay.textContent = val;
      if (caratTooltip) caratTooltip.textContent = val + ' carat';
    }

    if (caratSlider) {
      updateCaratSlider();
      caratSlider.addEventListener('input', updateCaratSlider);
      window.addEventListener('resize', updateCaratSlider);
    }

    /* ===================== Floating CTA (Mobile) ===================== */
    var mobileQuery = window.matchMedia('(max-width: 767px)');
    var floatingCta = document.querySelector('[data-floating-cta]');
    var floatingCtaBtn = document.querySelector('[data-floating-cta-btn]');
    var observer = null;

    function syncFloatingState() {
      if (!floatingCtaBtn || !addToCartBtn) return;
      floatingCtaBtn.textContent = addToCartBtn.value;
      floatingCtaBtn.disabled = addToCartBtn.disabled;
    }

    function initFloatingCta() {
      if (!floatingCta || !addToCartBtn) return;

      observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              floatingCta.classList.remove('floating-cta--visible');
            } else {
              syncFloatingState();
              floatingCta.classList.add('floating-cta--visible');
            }
          });
        },
        { threshold: 0 }
      );

      observer.observe(addToCartBtn);

      floatingCtaBtn.addEventListener('click', function () {
        addToCartBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }

    function destroyFloatingCta() {
      if (observer) {
        observer.disconnect();
        observer = null;
      }
      if (floatingCta) floatingCta.classList.remove('floating-cta--visible');
    }

    function handleMobileChange(e) {
      if (e.matches) {
        initFloatingCta();
      } else {
        destroyFloatingCta();
      }
    }

    mobileQuery.addEventListener('change', handleMobileChange);
    handleMobileChange(mobileQuery);

    /* Patch updateVariant to sync floating CTA state */
    var _origUpdateVariant = updateVariant;
    updateVariant = function () {
      _origUpdateVariant();
      syncFloatingState();
    };
  });
</script>

<script>
  (function () {
    function initMatchingSwipers() {
      document.querySelectorAll('[data-matching-products-swiper]').forEach(function (swiperEl) {
        if (swiperEl.matchingSwiper) return;
        if (typeof Swiper === 'undefined') return;

        var container = swiperEl.closest('.matching-products');
        if (!container) return;

        var prevBtn = container.querySelector('[data-matching-products-prev]');
        var nextBtn = container.querySelector('[data-matching-products-next]');

        swiperEl.matchingSwiper = new Swiper(swiperEl, {
          slidesPerView: 'auto',
          spaceBetween: 10,
          navigation: {
            prevEl: prevBtn,
            nextEl: nextBtn,
          },
        });
      });
    }

    document.addEventListener('DOMContentLoaded', initMatchingSwipers);
    document.addEventListener('shopify:section:load', initMatchingSwipers);
    initMatchingSwipers();
  })();
</script>

