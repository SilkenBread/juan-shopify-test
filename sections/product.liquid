      margin-bottom: 20px;
      padding: 32px 16px;
    }
    .matching-products__inner {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }
    .matching-products__carousel {
      width: 100%;
      flex: none;
    }
    .matching-products__text {
      flex: none;
      align-items: center;
      text-align: center;
    }
    .matching-products__swiper .swiper-slide {
      width: 180px;
    }
    .matching-card__image-link {
      height: 208px;
    }
  }

  /* ===================== Tablet (768px - 1279px) ===================== */
  @media screen and (min-width: 768px) and (max-width: 1279px) {
    .product-layout {
      padding: 0 40px;
    }
    .product-gallery__swiper {
      overflow: visible;
    }
    .product-gallery__swiper .swiper-wrapper {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      transform: none !important;
    }
    .product-gallery__swiper .swiper-wrapper .swiper-slide {
      width: 100% !important;
    }

    /* Matching Products — tablet */
    .matching-products {
      padding: 40px 0;
    }
    .matching-products__swiper .swiper-slide {
      width: 200px;
    }
    .matching-card__image-link {
      height: 260px;
    }
  }

  /* ===================== Desktop (min 1280px) ===================== */
  @media screen and (min-width: 1280px) {
    .product-layout {
      display: grid;
      grid-template-columns: 1fr 440px;
      gap: 40px;
      align-items: start;
      padding: 0 30px 120px 30px;
    }
    .product-gallery__swiper {
      overflow: visible;
    }
    .product-gallery__swiper .swiper-wrapper {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      transform: none !important;
    }
    .product-gallery__swiper .swiper-wrapper .swiper-slide {
      width: 100% !important;
    }
    .product-info {
      position: sticky;
      top: 130px;
      grid-row: 1 / 3;
      grid-column: 2;
    }

    /* Matching Products — desktop */
    .matching-products--desktop {
      grid-column: 1;
      grid-row: 2;
    }
    .matching-products__swiper .swiper-wrapper {
      justify-content: flex-end;
    }
  }

  /* ===================== Floating CTA (Mobile) ===================== */
  .floating-cta {
    display: none;
  }

  @media (max-width: 767px) {
    .floating-cta {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      z-index: 999;
      padding: 12px 16px;
      padding-bottom: calc(12px + env(safe-area-inset-bottom));
      transform: translateY(100%);
      opacity: 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
      pointer-events: none;
    }

    .floating-cta--visible {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .floating-cta__btn {
      display: flex;
      width: 100%;
      height: 48px;
      justify-content: center;
      align-items: center;
      background: #706a38;
      color: #fefdfc;
      font-size: 14px;
      font-weight: 500;
      border: none;
      cursor: pointer;
    }

    .floating-cta__btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
  }
{%- endstylesheet -%}

